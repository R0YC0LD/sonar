# ============================================================
#  ORTAM DEGISKENLERI  —  bu dosyayi ".env" olarak kopyala ve doldur
#  (cp .env.example .env)   Windows PowerShell:  Copy-Item .env.example .env
# ============================================================

# ----- FIREBASE (Console > Project Settings > Web App yapilandirmasindan al) -----
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ----- SPOTIFY (https://developer.spotify.com/dashboard 'ten uygulama olustur) -----
# Client ID: uygulamanin dashboard sayfasinda gorunur (Client Secret'a GEREK YOK, PKCE kullaniyoruz)
VITE_SPOTIFY_CLIENT_ID=

# Spotify Dashboard > Settings > Redirect URIs kismina EKLE:
#   http://127.0.0.1:5173/callback        (yerel gelistirme)
#   https://SENIN-SITEN.web.app/callback  (canli site)
VITE_SPOTIFY_REDIRECT_URI=http://127.0.0.1:5173/callback
